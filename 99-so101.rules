# SO-101 arm persistent device names with permissions
# Follower arm (serial: 5B3D048734)
SUBSYSTEM=="tty", ATTRS{idVendor}=="1a86", ATTRS{idProduct}=="55d3", ATTRS{serial}=="5B3D048734", SYMLINK+="so101_follower", MODE="0666"
# Leader arm (serial: 5B61034422)
SUBSYSTEM=="tty", ATTRS{idVendor}=="1a86", ATTRS{idProduct}=="55d3", ATTRS{serial}=="5B61034422", SYMLINK+="so101_leader", MODE="0666"
